# Optional: enables live RapidAPI calls for the individual search endpoints.
# If omitted, the backend returns deterministic tenant-scoped demo data.
RAPIDAPI_KEY=

# SQLite database used by the FastAPI backend.
DATABASE_URL=sqlite:///./fallback.db

# Optional Amadeus credentials for legacy /amadeus/* endpoints.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_HOSTNAME=test
